{
	"name": "@begit/cli",
	"version": "0.4.0",
	"description": "A CLI for using begit",
	"author": "Thomas Beer",
	"license": "MIT",
	"homepage": "https://github.com/Tommypop2/begit",
	"repository": {
		"type": "git",
		"url": "https://github.com/Tommypop2/begit"
	},
	"type": "module",
	"files": [
		"dist",
		"types"
	],
	"bin": {
		"begit": "./dist/index.mjs"
	},
	"module": "./dist/index.mjs",
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsc && tsdown",
		"start": "jiti src/index.ts"
	},
	"keywords": [
		"git",
		"template",
		"scaffolding",
		"cli"
	],
	"dependencies": {
		"@begit/core": "workspace:*",
		"@clack/prompts": "^1.7.0",
		"cmd-ts": "^0.15.0",
		"tiny-updater": "^3.7.0",
		"yoctocolors": "^2.1.2",
		"yocto-spinner": "^1.2.1"
	},
	"publishConfig": {
		"access": "public"
	}
}
